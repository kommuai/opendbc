import os
import platform
import subprocess

system = platform.system()
machine = platform.machine()
ka2 = os.path.isfile('/KA2')
repo_root = Dir('#').abspath

env = Environment(
  CFLAGS=[
    '-Wall',
    "-Wextra",
    '-Werror',
    '-nostdlib',
    '-fno-builtin',
    '-std=gnu11',
    '-Wfatal-errors',
    '-Wno-pointer-to-int-cast',
    '-g',
    '-O0',
    '-fno-omit-frame-pointer',
    '-DALLOW_DEBUG',
  ],
  LINKFLAGS=[
    '-fsanitize=undefined',
    '-fno-sanitize-recover=undefined',
  ],
  CPPPATH=["#"],
  tools=["default", "compilation_db"],
)

# The Mull plugin injects mutations that are dormant unless run with mull-runner
if system == "Darwin":
  mull_plugin = repo_root + '/.mull/lib/mull-ir-frontend-18'
elif ka2:
  mull_plugin = repo_root + '/.mull/root/usr/lib/mull-ir-frontend-18'
  if not os.path.exists(mull_plugin):
    mull_plugin = '/usr/lib/mull-ir-frontend-18'
else:
  mull_plugin = '/usr/lib/mull-ir-frontend-18'


def profile_runtime_lib(resource_dir):
  arch = machine
  if arch in ('arm64',):
    arch = 'aarch64'
  profile_name = f'libclang_rt.profile-{arch}.a'
  return os.path.join(resource_dir, 'lib', 'linux', profile_name)


def find_clang_resource_dir():
  merged = repo_root + '/.llvm/clang-resource'
  if os.path.exists(profile_runtime_lib(merged)):
    return merged
  env_resource = os.environ.get('CLANG_RESOURCE_DIR')
  if env_resource and os.path.exists(profile_runtime_lib(env_resource)):
    return env_resource
  try:
    system_res = subprocess.check_output(['clang-18', '-print-resource-dir'], text=True).strip()
    if os.path.exists(profile_runtime_lib(system_res)):
      return system_res
  except (FileNotFoundError, subprocess.CalledProcessError):
    pass
  local = repo_root + '/.llvm/root/usr/lib/llvm-18/lib/clang/18'
  if os.path.exists(profile_runtime_lib(local)):
    return local
  return None


if os.path.exists(mull_plugin):
  if ka2 and system == "Linux":
    resource_dir = find_clang_resource_dir()
    if resource_dir is None:
      print("warning: libclang_rt.profile not found; building without Mull")
    else:
      env['CC'] = 'clang-18'
      env.Append(CPPPATH=[repo_root])
      env.Append(CCFLAGS=[
        f'-resource-dir={resource_dir}',
        f'-I{repo_root}',
        '-grecord-command-line',
      ])
      env.Append(CFLAGS=['-fprofile-arcs', '-ftest-coverage', f'-fpass-plugin={mull_plugin}'])
      env.Append(LINKFLAGS=['-fprofile-arcs', '-ftest-coverage', f'-resource-dir={resource_dir}'])
      local_mull_bin = repo_root + '/.mull/root/usr/bin'
      if os.path.isdir(local_mull_bin):
        env.PrependENVPath('PATH', local_mull_bin)
  else:
    # Docker / CI / macOS: original Mull build path
    env['CC'] = 'clang-18'
    env.Append(CFLAGS=['-fprofile-arcs', '-ftest-coverage', f'-fpass-plugin={mull_plugin}'])
    env.Append(LINKFLAGS=['-fprofile-arcs', '-ftest-coverage'])
    if system == "Darwin":
      env.PrependENVPath('PATH', '/opt/homebrew/opt/llvm@18/bin')

safety = env.SharedObject("safety.os", "safety.c")
libsafety = env.SharedLibrary("libsafety.so", [safety])

# GCC-style note file is generated by compiler, allow scons to clean it up
env.SideEffect("safety.gcno", safety)
