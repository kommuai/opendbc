CM_ SG_ 269 GEAR "D is 4, N is 3, R is 2, P is 1";
CM_ SG_ 768 GEAR "Omoda 5: 0x300 byte0 bits 0-3. 0xB=D 0xC=N 0xD=R 0xE=P.";
CM_ SG_ 666 AUTO_HOLD "Only gear D it will be active";
CM_ SG_ 666 BRAKE_PRESSURE "Offset -0.2 removes ~0.2 idle bias (Jaecoo J7); scale 0.002 unchanged.";
CM_ SG_ 903 FOLLOW_DISTANCE "Jaecoo J7 ACC gap bars on HUD byte1 bits 9-11 (3-bit LE). Raw 1=1 bar (min gap) .. raw 5=5 bars (max gap); 0/6/7 unknown.";
CM_ SG_ 903 HANDS_ON_WHEEL_STEER "HUD 0x387 byte0 bit4 (0x10): 'ACC cancelled / uncertain' indicator the cluster latches AFTER cruise drops to CRUISE_STATE=1. NOT the active in-LKAS hands-on-wheel icon — CarController re-emits HUD on PT with this bit forced 0 to suppress spurious cancel glyphs.";
CM_ SG_ 903 CANCEL_CRUISE_UNCERTAIN "HUD 0x387 byte0 bit5 (0x20).";
CM_ SG_ 933 HANDS_ON_WHEEL_WARN "LKA_STATUS 0x3a5 byte5 bit4 (0x10). Co-fires with the HUD cancel indicator after cruise drops — not the active in-LKAS hands-on-wheel icon.";
CM_ BO_ 647 "Driver seatbelt: byte3 bit1 (Intel start bit 25) set when unbuckled (Jaecoo J7 log).";
CM_ BO_ 1072 "Driver seatbelt: byte5 bit6 (Intel start bit 46) set when unbuckled (Jaecoo J7 log).";
CM_ BO_ 295 "BCM 0x127 (optional): door-related bytes vary; not present on every latch event — do not use alone for doorOpen.";
CM_ BO_ 913 "CAN 0x391 STALK+BCM. Door: PAYLOAD391_B3 (wire byte3) 0x08 latched vs 0x09 ajar — use LSB (byte3&1), not B1/B6 (counter).";
CM_ SG_ 913 GENERIC_TOGGLE "Stalk/aux toggle -> carState.genericToggle; byte0 bit2 set (0xCC..) vs clear (0xC8..).";
CM_ BO_ 914 "BCM 0x392 (Jaecoo J7): raw BCM; door decode uses 0x391 PAYLOAD391_B3 as in CM_ BO_ 913.";
CM_ BO_ 1042 "BCM frame 0x412; trailing bytes roll (counter) in capture.";
CM_ BO_ 1125 "BCM frame 0x465; single sample in door-close capture — label for follow-up.";
CM_ SG_ 903 CRUISE_STATE "3 is ENABLE, 2 is READY, 1 is IDLE";
CM_ SG_ 467 STEERING_ANGLE "Jaecoo J7: offset -780.1 removes ~7.1 deg bias at straight-ahead vs -773.";
CM_ SG_ 196 STEERING_ANGLE "0xC4 bytes0-1 motorola 16-bit. iCaur03: road-wheel angle factor 0.06 offset -1985 (retuned from -1966 using straightish median bias ~19° on route 2026-07-15--03-08-40 so paramsd |angleOffset|<10). Jaecoo: same bits formerly STEERING_ANGLE_NOT_CALIBRATED (raw>=36000 ≈ phys 175 deg with this scale = intervention).";
CM_ SG_ 196 DRIVER_TORQUE "iCaur03: 0xC4 start bit 23, 8-bit unsigned driver torque (byte2). Scale 1.";
CM_ BO_ 196 "Chery 0xC4 STEER_RELATED: iCaur angle+torque; Jaecoo also uses this ID.";
CM_ SG_ 837 STEER_CMD_ANGLE "Match EPS STEERING_ANGLE scale/offset for LANE_KEEP TX.";
CM_ SG_ 864 ICC_TOGGLE "Cruise on/off (byte3 bit0).";
CM_ SG_ 864 CRUISE_BUTTON "Cruise SET (byte4 bit0, mask 0x01). Verified on capture 2026-05-26.";
CM_ SG_ 864 RES_BUTTON "RES / resume (byte3 bit6, mask 0x40); 3-5 frames per tap.";
CM_ SG_ 775 LKAS_FAULT "Camera-broadcast LKAS fault flag (byte0 bit6). Set when EPS rejects LKAS, e.g. driver torque overpowers (route 2026-05-20--05-56-41 t=454.06: 0x80->0x40 the instant LKAS_ENABLE in 0x394 drops).";
CM_ SG_ 775 LKAS_AVAILABLE "Camera LKAS-OK flag (byte0 bit7); inverse of LKAS_FAULT.";
CM_ SG_ 864 CHECKSUM_BUTTONS "Byte 0; Chrysler-style CRC over bytes 1..5 (Jaecoo J7 route 2026-05-14--07-49-04).";
CM_ BO_ 546 "iCaur 03 wheel speed A (0x222). 13-bit motorola (byte0 + top 5 of byte1; low 3 of byte1 unused by speed). DBC scale 1 (raw counts); CarInterface wheelSpeedFactor~0.01756 -> m/s (GPS origin-fit on rlog 2026-07-13--04-13-59; replaces prior 8-bit*0.55). Offset 0 so raw=0 is standstill. Bytes 0-1 / 2-3 track together (vehicle-speed duplicate, not independent wheels).";
CM_ BO_ 547 "iCaur 03 wheel speed B (0x223). Same 13-bit encoding as 0x222; byte pairs duplicate vehicle speed.";
CM_ BO_ 306 "iCaur 03 brake pressure (0x132 start bit 31, 8-bit motorola). DBC scale 0.01 so raw 100 → 1.0; CarState uses 0..1.";
CM_ BO_ 330 "iCaur 03 gas pedal (0x14A start bit 23, 12-bit motorola). phys=(raw-2000)/1000 so idle raw 2000→0 and raw 3000→1.0.";
CM_ BO_ 581 "iCaur 03 stalk/blinker (0x245 start bit 11, 4-bit). Left=4|6, right=8|9.";
CM_ SG_ 581 BLINKER "iCaur03: left when 4 or 6; right when 8 or 9.";
CM_ BO_ 789 "iCaur 03 transmission (0x315 start bit 11, 4-bit gear).";
CM_ SG_ 789 GEAR "iCaur03: P=11 D=1 N=10 R=9.";

VAL_ 768 GEAR 11 "D" 12 "N" 13 "R" 14 "P";
VAL_ 581 BLINKER 4 "LEFT" 6 "LEFT" 8 "RIGHT" 9 "RIGHT";
VAL_ 789 GEAR 1 "D" 9 "R" 10 "N" 11 "P";
VAL_ 903 FOLLOW_DISTANCE 0 "UNKNOWN" 1 "1_BAR" 2 "2_BAR" 3 "3_BAR" 4 "4_BAR" 5 "5_BAR" 6 "UNKNOWN" 7 "UNKNOWN";
VAL_ 903 HANDS_ON_WHEEL_STEER 0 "NORMAL" 1 "ACC_CANCELLED_INDICATOR";
VAL_ 933 HANDS_ON_WHEEL_WARN 0 "NO_WARNING" 1 "WARNING";
VAL_ 913 GENERIC_TOGGLE 0 "OFF" 1 "ON";

