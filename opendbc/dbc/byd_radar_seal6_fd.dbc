VERSION ""

# BYD Seal 6 front radar (CAN-FD bus 1).
# Reverse-engineered from stock logs (2026-07-16--06-20-47).
# 16 object frames per cycle: 0x670..0x67f (64 bytes each), trigger on 0x67f.
# Header/status: 0x64e (8B), 0x66f (16B) — not required for track parsing.

